<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <!-- 建立群組表 -->
    <changeSet id="20260511-001" author="wafer-bi">
        <createTable tableName="groups">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints unique="true" nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- 建立選單表 -->
    <changeSet id="20260511-002" author="wafer-bi">
        <createTable tableName="menus">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(100)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="path" type="VARCHAR(255)"/>
            <column name="icon" type="VARCHAR(100)"/>
        </createTable>
    </changeSet>

    <!-- 建立選單群組關聯表 -->
    <changeSet id="20260511-003" author="wafer-bi">
        <createTable tableName="menu_groups">
            <column name="group_id" type="INTEGER">
                <constraints nullable="false" foreignKeyName="fk_group_menu_group" referencedTableName="groups" referencedColumnNames="id"/>
            </column>
            <column name="menu_id" type="INTEGER">
                <constraints nullable="false" foreignKeyName="fk_group_menu_menu" referencedTableName="menus" referencedColumnNames="id"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="menu_groups" columnNames="group_id, menu_id"/>
    </changeSet>

    <!-- 更新用戶表加入 group_id -->
    <changeSet id="20260511-004" author="wafer-bi">
        <addColumn tableName="users">
            <column name="group_id" type="INTEGER">
                <constraints foreignKeyName="fk_user_group" referencedTableName="groups" referencedColumnNames="id"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
