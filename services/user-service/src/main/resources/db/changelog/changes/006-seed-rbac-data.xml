<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <!-- Seed Roles and Menus -->
    <changeSet id="20260513-001" author="wafer-bi">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM auth_groups WHERE name = 'admin'</sqlCheck>
        </preConditions>
        <insert tableName="auth_groups">
            <column name="name" value="admin"/>
        </insert>
        <insert tableName="auth_groups">
            <column name="name" value="user"/>
        </insert>
    </changeSet>

    <changeSet id="20260513-002" author="wafer-bi">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM menus</sqlCheck>
        </preConditions>
        <insert tableName="menus">
            <column name="name" value="Lot Overview"/>
            <column name="code" value="lot-overview"/>
        </insert>
        <insert tableName="menus">
            <column name="name" value="Wafer Detail"/>
            <column name="code" value="wafer-detail"/>
        </insert>
        <insert tableName="menus">
            <column name="name" value="Statistical Analysis"/>
            <column name="code" value="statistical-analysis"/>
        </insert>
    </changeSet>

    <!-- Grant all menus to admin group -->
    <changeSet id="20260513-003" author="wafer-bi">
        <sql>
            INSERT INTO menu_groups (group_id, menu_id)
            SELECT g.id, m.id FROM auth_groups g, menus m
            WHERE g.name = 'admin'
            AND NOT EXISTS (SELECT 1 FROM menu_groups mg WHERE mg.group_id = g.id AND mg.menu_id = m.id);
        </sql>
    </changeSet>

</databaseChangeLog>
